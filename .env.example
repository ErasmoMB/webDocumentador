# Configuración del frontend
# Establece USE_MOCK_DATA=true para usar datos locales (desarrollo sin backend)
USE_MOCK_DATA=false

# URL del backend API
# Desarrollo local:
API_URL=http://localhost:3000
# Producción (Render):
API_URL=https://backend-api-lbs.onrender.com

# Ruta de datos mock (no modificar)
MOCK_DATA_PATH=assets/mockData

# Entorno de ejecución
NODE_ENV=production
